{
    "triggers": [
      {
        "id": "alarm_triggered",
        "title": {
          "en": "An alarm goes off"
        },
        "hint": {
          "en": "When an alarm starts the wake-up sequence on the device"
        },
        "titleFormatted": {
          "en": "Alarm [[alarm]] goes off"
        },
        "args": [
          {
            "type": "autocomplete",
            "name": "alarm",
            "title": {
              "en": "Alarm"
            },
            "placeholder": {
              "en": "Any alarm"
            }
          }
        ],
        "tokens": [
          {
            "name": "alarm_id",
            "type": "number",
            "title": {
              "en": "Alarm number"
            }
          },
          {
            "name": "alarm_time",
            "type": "string",
            "title": {
              "en": "Alarm time"
            },
            "example": {
              "en": "07:30"
            }
          }
        ]
      },
      {
        "id": "sunset_false",
        "title": {
          "en": "The sunset mode is deactivated"
        },
        "hint": {
          "en": "When the sunset mode is deactivated"
        },
        "$filter": "capabilities=sunset"
      },
      {
        "id": "sunset_true",
        "title": {
          "en": "The sunset mode is activated"
        },
        "hint": {
          "en": "When the sunset mode is activated"
        },
        "$filter": "capabilities=sunset"
      },
      {
        "id": "nightlight_false",
        "title": {
          "en": "The nightlight is turned off"
        },
        "hint": {
          "en": "When the nightlight has been turned off"
        },
        "$filter": "capabilities=nightlight"
      },
      {
        "id": "nightlight_true",
        "title": {
          "en": "The nightlight is turned on"
        },
        "hint": {
          "en": "When the nightlight has been turned on"
        },
        "$filter": "capabilities=nightlight"
      },
      {
        "id": "sunrise_preview_false",
        "title": {
          "en": "The sunrise preview is deactivated"
        },
        "hint": {
          "en": "When the sunrise preview has been turned off"
        },
        "$filter": "capabilities=sunrise_preview"
      },
      {
        "id": "sunrise_preview_true",
        "title": {
          "en": "The sunrise preview is activated"
        },
        "hint": {
          "en": "When the sunrise preview has been turned on"
        },
        "$filter": "capabilities=sunrise_preview"
      },
      {
        "id": "relax_breathe_false",
        "title": {
          "en": "Relax breathe is stopped"
        },
        "hint": {
          "en": "When the relax breathe program has stopped"
        },
        "$filter": "capabilities=relax_breathe"
      },
      {
        "id": "relax_breathe_true",
        "title": {
          "en": "Relax breathe is started"
        },
        "hint": {
          "en": "When the relax breathe program has started"
        },
        "$filter": "capabilities=relax_breathe"
      }
    ],
    "conditions": [
      {
        "id": "alarm_enabled",
        "title": {
          "en": "An alarm !{{is|is not}} enabled"
        },
        "titleFormatted": {
          "en": "Alarm [[alarm]] !{{is|is not}} enabled"
        },
        "hint": {
          "en": "Checks whether the selected alarm is currently enabled on the device"
        },
        "args": [
          {
            "type": "autocomplete",
            "name": "alarm",
            "title": {
              "en": "Alarm"
            }
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "set_alarm_enabled",
        "title": {
          "en": "Enable or disable an alarm"
        },
        "hint": {
          "en": "Enables or disables the selected alarm on the device"
        },
        "titleFormatted": {
          "en": "Set alarm [[alarm]] to [[state]]"
        },
        "args": [
          {
            "type": "autocomplete",
            "name": "alarm",
            "title": {
              "en": "Alarm"
            }
          },
          {
            "type": "dropdown",
            "name": "state",
            "title": {
              "en": "State"
            },
            "values": [
              { "id": "true", "title": { "en": "Enabled" } },
              { "id": "false", "title": { "en": "Disabled" } }
            ]
          }
        ]
      },
        {
            "id": "set-sunset",
            "title": {
              "en": "Start sunset"
            },
            "hint": {
              "en": "Toggles the sunset mode of the wake-up light"
            },
            "titleFormatted": {
              "en": "Turns the sunset mode on or off: [[start]]"
            },
            "$filter": "capabilities=sunset",
            "args": [
              {
                "type": "checkbox",
                "name": "start",
                "title": {
                  "en": "Start"
                },
                "placeholder": {
                  "en": "yes"
                }
              }
            ]
          },
          {
            "id": "set-nightlight",
            "title": {
              "en": "Set the nightligh"
            },
            "hint": {
              "en": "Toggles the nightlight"
            },
            "titleFormatted": {
              "en": "Turns the nightlight on or off: [[mode]]"
            },
            "$filter": "capabilities=nightlight",
            "args": [
              {
                "type": "checkbox",
                "name": "mode",
                "title": {
                  "en": "On"
                },
                "placeholder": {
                  "en": "yes"
                }
              }
            ]
          },
          {
            "id": "set-sunrise-preview",
            "title": {
              "en": "Start sunrise preview"
            },
            "hint": {
              "en": "Toggles the sunrise preview of the wake-up light"
            },
            "titleFormatted": {
              "en": "Turns the sunrise preview on or off: [[mode]]"
            },
            "$filter": "capabilities=sunrise_preview",
            "args": [
              {
                "type": "checkbox",
                "name": "mode",
                "title": {
                  "en": "On"
                },
                "placeholder": {
                  "en": "yes"
                }
              }
            ]
          },
          {
            "id": "set-relax-breathe",
            "title": {
              "en": "Start relax breathe"
            },
            "hint": {
              "en": "Toggles the relax breathe program of the wake-up light"
            },
            "titleFormatted": {
              "en": "Turns the relax breathe program on or off: [[mode]]"
            },
            "$filter": "capabilities=relax_breathe",
            "args": [
              {
                "type": "checkbox",
                "name": "mode",
                "title": {
                  "en": "On"
                },
                "placeholder": {
                  "en": "yes"
                }
              }
            ]
          }
         ]
}