{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.philips.somneo",
  "version": "1.1.0",
  "compatibility": ">=5.0.0",
  "brandColor": "#4C3628",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Philips Sleepmapper"
  },
  "description": {
    "en": "Monitor and improve your sleeping."
  },
  "category": [
    "lights"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Vincent Boer",
    "email": "vincent@vdboer.nl"
  },
  "flow": {
    "triggers": [
      {
        "id": "alarm_triggered",
        "title": {
          "en": "An alarm goes off"
        },
        "hint": {
          "en": "When an alarm starts the wake-up sequence on the device"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=wakeup-light"
          }
        ]
      },
      {
        "id": "sunset_false",
        "title": {
          "en": "The sunset mode is deactivated"
        },
        "hint": {
          "en": "When the sunset mode is deactivated"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=wakeup-light&capabilities=sunset"
          }
        ]
      },
      {
        "id": "sunset_true",
        "title": {
          "en": "The sunset mode is activated"
        },
        "hint": {
          "en": "When the sunset mode is activated"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=wakeup-light&capabilities=sunset"
          }
        ]
      },
      {
        "id": "nightlight_false",
        "title": {
          "en": "The nightlight is turned off"
        },
        "hint": {
          "en": "When the nightlight has been turned off"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=wakeup-light&capabilities=nightlight"
          }
        ]
      },
      {
        "id": "nightlight_true",
        "title": {
          "en": "The nightlight is turned on"
        },
        "hint": {
          "en": "When the nightlight has been turned on"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=wakeup-light&capabilities=nightlight"
          }
        ]
      },
      {
        "id": "sunrise_preview_false",
        "title": {
          "en": "The sunrise preview is deactivated"
        },
        "hint": {
          "en": "When the sunrise preview has been turned off"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=wakeup-light&capabilities=sunrise_preview"
          }
        ]
      },
      {
        "id": "sunrise_preview_true",
        "title": {
          "en": "The sunrise preview is activated"
        },
        "hint": {
          "en": "When the sunrise preview has been turned on"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=wakeup-light&capabilities=sunrise_preview"
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "set-sunset",
        "title": {
          "en": "Start sunset"
        },
        "hint": {
          "en": "Toggles the sunset mode of the wake-up light"
        },
        "titleFormatted": {
          "en": "Turns the sunset mode on or off: [[start]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=wakeup-light&capabilities=sunset"
          },
          {
            "type": "checkbox",
            "name": "start",
            "title": {
              "en": "Start"
            },
            "placeholder": {
              "en": "yes"
            }
          }
        ]
      },
      {
        "id": "set-nightlight",
        "title": {
          "en": "Set the nightligh"
        },
        "hint": {
          "en": "Toggles the nightlight"
        },
        "titleFormatted": {
          "en": "Turns the nightlight on or off: [[mode]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=wakeup-light&capabilities=nightlight"
          },
          {
            "type": "checkbox",
            "name": "mode",
            "title": {
              "en": "On"
            },
            "placeholder": {
              "en": "yes"
            }
          }
        ]
      },
      {
        "id": "set-sunrise-preview",
        "title": {
          "en": "Start sunrise preview"
        },
        "hint": {
          "en": "Toggles the sunrise preview of the wake-up light"
        },
        "titleFormatted": {
          "en": "Turns the sunrise preview on or off: [[mode]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=wakeup-light&capabilities=sunrise_preview"
          },
          {
            "type": "checkbox",
            "name": "mode",
            "title": {
              "en": "On"
            },
            "placeholder": {
              "en": "yes"
            }
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Wakeup light"
      },
      "class": "sensor",
      "capabilities": [
        "dim",
        "measure_humidity",
        "measure_luminance",
        "measure_noise",
        "measure_temperature",
        "onoff"
      ],
      "settings": [
        {
          "type": "group",
          "label": {
            "en": "Sunset"
          },
          "children": [
            {
              "id": "sunset_duration",
              "type": "number",
              "label": {
                "en": "Duration"
              },
              "value": 30,
              "min": 5,
              "max": 60,
              "units": {
                "en": "minutes"
              }
            },
            {
              "id": "sunset_light_intensity",
              "type": "number",
              "label": {
                "en": "Light intensity"
              },
              "value": 20,
              "min": 1,
              "max": 25
            },
            {
              "id": "sunset_color_scheme",
              "type": "dropdown",
              "label": {
                "en": "Color scheme"
              },
              "value": "0",
              "values": [
                { "id": "0", "label": { "en": "Sunny Day" } },
                { "id": "1", "label": { "en": "Island Red" } },
                { "id": "2", "label": { "en": "Nordic White" } },
                { "id": "3", "label": { "en": "Caribbean Red" } }
              ]
            },
            {
              "id": "sunset_ambient_sound",
              "type": "dropdown",
              "label": {
                "en": "Ambient sound"
              },
              "value": "off",
              "values": [
                { "id": "off", "label": { "en": "No sound" } },
                { "id": "1", "label": { "en": "Soft Rain" } },
                { "id": "2", "label": { "en": "Ocean Waves" } },
                { "id": "3", "label": { "en": "Under Water" } },
                { "id": "4", "label": { "en": "Summer Lake" } },
                { "id": "fmr", "label": { "en": "FM Radio" } },
                { "id": "aux", "label": { "en": "AUX Input" } }
              ]
            },
            {
              "id": "sunset_ambient_radio_channel",
              "type": "dropdown",
              "label": {
                "en": "FM radio channel (when ambient sound is FM Radio)"
              },
              "value": "1",
              "values": [
                { "id": "1", "label": { "en": "Channel 1" } },
                { "id": "2", "label": { "en": "Channel 2" } },
                { "id": "3", "label": { "en": "Channel 3" } },
                { "id": "4", "label": { "en": "Channel 4" } },
                { "id": "5", "label": { "en": "Channel 5" } }
              ]
            },
            {
              "id": "sunset_ambient_volume",
              "type": "number",
              "label": {
                "en": "Ambient sound volume"
              },
              "value": 12,
              "min": 0,
              "max": 25
            }
          ]
        },
        {
          "type": "group",
          "label": {
            "en": "Sunrise preview"
          },
          "children": [
            {
              "id": "sunrise_color_scheme",
              "type": "dropdown",
              "label": {
                "en": "Color scheme"
              },
              "value": "0",
              "values": [
                { "id": "0", "label": { "en": "Sunny Day" } },
                { "id": "1", "label": { "en": "Island Red" } },
                { "id": "2", "label": { "en": "Nordic White" } },
                { "id": "3", "label": { "en": "Caribbean Red" } }
              ]
            }
          ]
        }
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "images": {
        "small": "/drivers/wakeup-light/assets/images/small.png",
        "large": "/drivers/wakeup-light/assets/images/large.png",
        "xlarge": "/drivers/wakeup-light/assets/images/xlarge.png"
      },
      "discovery": "SSDP",
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "options": {
            "singular": true
          },
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "id": "wakeup-light"
    }
  ],
  "capabilities": {
    "bedtime_tracking": {
      "type": "boolean",
      "title": {
        "en": "Sleep Tracking"
      },
      "insights": true,
      "insightsTitleTrue": {
        "en": "Sleep tracking was turned on"
      },
      "insightsTitleFalse": {
        "en": "Sleep tracking was turned off"
      },
      "getable": true,
      "setable": true,
      "uiComponent": "button",
      "uiQuickAction": true
    },
    "sunrise_preview": {
      "type": "boolean",
      "title": {
        "en": "Sunrise Preview"
      },
      "insights": true,
      "insightsTitleTrue": {
        "en": "The sunrise preview was activated"
      },
      "insightsTitleFalse": {
        "en": "The sunrise preview was deactivated"
      },
      "getable": true,
      "setable": true,
      "uiComponent": "button",
      "uiQuickAction": true
    },
    "nightlight": {
      "type": "boolean",
      "title": {
        "en": "Night Light"
      },
      "insights": true,
      "insightsTitleTrue": {
        "en": "The nightlight was turned on"
      },
      "insightsTitleFalse": {
        "en": "The nightlight was turned off"
      },
      "getable": true,
      "setable": true,
      "uiComponent": "button",
      "uiQuickAction": true
    },
    "sunset": {
      "type": "boolean",
      "title": {
        "en": "Sunset"
      },
      "insights": true,
      "insightsTitleTrue": {
        "en": "The sunset was activated"
      },
      "insightsTitleFalse": {
        "en": "The sunset was deactivated"
      },
      "getable": true,
      "setable": true,
      "uiComponent": "button",
      "uiQuickAction": true
    }
  },
  "discovery": {
    "SSDP": {
      "type": "ssdp",
      "ssdp": {
        "search": "urn:philips-com:device:DiProduct:1"
      },
      "id": "{{headers.usn}}",
      "conditions": [
        [
          {
            "field": "headers.st",
            "match": {
              "type": "string",
              "value": "philips-com:device:DiProduct:1"
            }
          }
        ]
      ]
    }
  }
}